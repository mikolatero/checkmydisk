    "No self-test history was reported. Some NVMe and USB devices do not expose self-test capabilities." : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "No se reportó histórico de auto-tests. Algunos dispositivos NVMe y USB no exponen esta capacidad." } } } },
    "Self-test started. Waiting for drive status..." : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "Auto-test iniciado. Esperando el estado del disco..." } } } },

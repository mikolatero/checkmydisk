    "This drive did not report SMART errors or does not expose an error log." : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "Este disco no reportó errores SMART o no expone un registro de errores." } } } },
    "Device Statistics are optional and this drive did not expose them through smartctl." : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "Las estadísticas del dispositivo son opcionales y este disco no las expone a través de smartctl." } } } },

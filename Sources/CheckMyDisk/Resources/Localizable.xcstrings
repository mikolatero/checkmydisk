    "Refresh interval" : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "Intervalo de actualización" } } } },
    "Every %lld minutes" : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "Cada %lld minutos" } } } },
    "Local notifications on worsening status" : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "Notificaciones locales si el estado empeora" } } } },
    "Keep history for" : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "Conservar histórico durante" } } } },
    "%lld days" : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "%lld días" } } } },
    "Snapshots are stored on every check and feed the History charts." : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "Cada comprobación guarda una instantánea que alimenta las gráficas del histórico." } } } },
    "Reports" : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "Informes" } } } },
    "Anonymize serial numbers and WWN in reports" : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "Anonimizar números de serie y WWN en los informes" } } } },
    "Changes are saved automatically." : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "Los cambios se guardan automáticamente." } } } },
    "Bundled first" : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "Primero el integrado" } } } },
    "Homebrew first" : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "Primero Homebrew" } } } },
    "Built-in SMART status failed" : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "El estado SMART integrado ha fallado" } } } },
    "The drive firmware reports a failing SMART state. Back up important data now." : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "El firmware del disco reporta un estado SMART de fallo. Haz copia de seguridad de los datos importantes ahora." } } } },
    "Raw value %@ is outside the expected range for this indicator." : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "El valor bruto %@ está fuera del rango esperado para este indicador." } } } },
    "The drive reports this attribute as failed (%@)." : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "El disco reporta este atributo como fallido (%@)." } } } },
    "NVMe critical warning" : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "Aviso crítico NVMe" } } } },
    "The NVMe critical warning bitmask is %lld." : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "La máscara de aviso crítico NVMe es %lld." } } } },
    "NVMe media errors" : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "Errores de medio NVMe" } } } },
    "%llu media/data integrity errors have been reported." : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "Se han reportado %llu errores de integridad de datos/medio." } } } },
    "Available spare below threshold" : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "Reserva disponible por debajo del umbral" } } } },
    "SSD lifetime consumed" : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "Vida útil del SSD consumida" } } } },
    "High temperature" : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "Temperatura alta" } } } },
    "Current temperature is %lld °C." : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "La temperatura actual es de %lld °C." } } } },
    "smartctl reports the disk as failing" : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "smartctl reporta el disco como fallando" } } } },
    "The smartctl exit status has the DISK FAILING bit set. Back up important data now." : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "El código de salida de smartctl tiene activo el bit de DISCO FALLANDO. Haz copia de seguridad ahora." } } } },
    "Pre-fail attributes below threshold" : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "Atributos pre-fallo por debajo del umbral" } } } },
    "One or more pre-fail attributes are at or below their failure threshold." : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "Uno o más atributos pre-fallo están en o por debajo de su umbral de fallo." } } } },
    "Attributes were below threshold in the past" : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "Hubo atributos por debajo del umbral en el pasado" } } } },
    "Some attributes have been at or below their threshold at some point in the drive's life." : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "Algunos atributos han estado en o por debajo de su umbral en algún momento de la vida del disco." } } } },
    "SMART data may be incomplete" : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "Los datos SMART pueden estar incompletos" } } } },
    "smartctl could not fully talk to this device; some values may be missing or stale." : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "smartctl no pudo comunicarse completamente con este dispositivo; pueden faltar valores o estar desactualizados." } } } },
    "smartctl reported an error" : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "smartctl reportó un error" } } } },
    "Not found" : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "No encontrado" } } } },
    "No smartctl executable was found. Install smartmontools or add a bundled smartctl resource." : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "No se encontró ningún ejecutable de smartctl. Instala smartmontools o añade un smartctl integrado en la app." } } } },
    "%@ has %lld health issue(s)." : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "%1$@ tiene %2$lld problema(s) de salud." } } } },
    "%@ did not finish within %lld seconds and was terminated." : { "localizations" : { "es" : { "stringUnit" : { "state" : "translated", "value" : "%1$@ no terminó en %2$lld segundos y fue finalizado." } } } }
  }
}
